      {
        "id": "m_stack_reid_001",
        "name": "Seguimiento y Búsqueda Semántica (Re-ID)",
        "version": "",
        "status": "poc",
        "responsible": "Jonathan Flores",
        "description": "Sistema de búsqueda y re-identificación de personas y vehículos. Opera en dos etapas: enrolamiento (construye galería de features desde video o foto del objetivo) y búsqueda (localiza al objetivo en streams RTSP o video). Usa descripción en lenguaje natural para localizar al objetivo en el primer frame válido.",
        "tech": "LocateAnything-3B, SAMURAI (SAM2), YOLO11x, CLIP ViT-L/14, TransReID, ResNet50",
        "notes": "Estado: Pruebas de integración local en curso.",
        "created_at": "2026-06-01"
      },
      {
        "id": "m_stack_parking_002",
        "name": "Monitoreo de Estacionamiento",
        "version": "",
        "status": "poc",
        "responsible": "Jonathan Flores",
        "description": "Monitor de ocupación de cajones de estacionamiento en tiempo real. Detecta qué cajones están libres u ocupados usando YOLO11x sobre zonas configurables. Además verifica el vehículo registrado en cada cajón mediante similitud visual coseno (ResNet50), color dominante HSV y lectura de placa (en desarrollo).",
        "tech": "YOLO11x, ResNet50, MobileNetV3, HSV Color, OCR Placas",
        "notes": "Estado: Primera versión funcional, primeras pruebas.",
        "created_at": "2026-06-01"
      },
      {
        "id": "m_stack_crowd_003",
        "name": "Conteo de Multitudes",
        "version": "",
        "status": "poc",
        "responsible": "Jonathan Flores",
        "description": "Conteo de personas en escenas densas desde cámaras altas (personas de 15–60 px). Divide el frame en un grid de patches (2×4), hace zoom individual por patch y corre YOLO en cada uno, luego aplica NMS global para eliminar duplicados en bordes solapados. Suavizado temporal con media móvil.",
        "tech": "YOLO11x, Patch Grid 2×4, NMS Global, Temporal Smooth",
        "notes": "Estado: Prueba de concepto, sin versión asignada.",
        "created_at": "2026-06-01"
      },
      {
        "id": "m_stack_fire_ir_004",
        "name": "Detección de Incendio IR",
        "version": "",
        "status": "poc",
        "responsible": "Jonathan Flores",
        "description": "Versión especializada para cámaras infrarrojas y visión nocturna. A diferencia del modelo RGB, usa máscara HSV de brillo alto y zona amarillo-caliente, CLAHE para contraste IR, flickering gate temporal y prompts CLIP adaptados para imágenes termales. Score combinado: coherencia de keyframes + concentración espacial + coherencia temporal.",
        "tech": "CLIP ViT-L/14, MOG2, CLAHE, KSM, WinCLIP, IR / Nocturno",
        "notes": "Estado: Prueba de concepto, primeras pruebas locales.",
        "created_at": "2026-06-01"
      },
      {
        "id": "m_1781063286682_qwk",
        "name": "Contador de Piezas",
        "version": "",
        "status": "poc",
        "responsible": "Jonathan Flores",
        "description": "El Contador de Piezas es un modelo de visión artificial en tiempo real (online) diseñado para automatizar la detección, clasificación y conteo de componentes industriales y de ferretería (como tuercas y tornillos) mediante el procesamiento de un flujo de video continuo. Como Prueba de Concepto (PoC), el sistema localiza visualmente cada objeto en movimiento, identifica su categoría específica sin importar su orientación y rastrea su trayectoria para asegurar que cada elemento sea contabilizado una única vez.",
        "tech": "YOLO11x",
        "notes": "",
        "created_at": "2026-06-10"
      }
    ]
